datadir="/var/lib/proxysql"

admin_variables=
{
  admin_credentials="admin:admin"
  mysql_ifaces="0.0.0.0:6032"
}

mysql_variables=
{
  threads=4
  max_connections=2048
  default_query_delay=0
  default_query_timeout=36000000
  have_compress=true
  poll_timeout=2000
  interfaces="0.0.0.0:6033"
  default_schema="FlashSale"
  stacksize=1048576
  server_version="8.0.45"
  monitor_username="monitor"
  monitor_password="monitor123"
  monitor_connect_interval=2000
  monitor_ping_interval=2000
  monitor_read_only_interval=1500
  monitor_read_only_timeout=500
}

mysql_servers =
(
  { address="mysql-primary", port=3306, hostgroup=10, max_connections=200 },
  { address="mysql-replica", port=3306, hostgroup=20, max_connections=200 }
)

mysql_users =
(
  { username="appuser", password="app_pass", default_hostgroup=10, active=1, transaction_persistent=1 }
)

mysql_query_rules =
(
  { rule_id=1, active=1, match_digest="^SELECT.*FOR UPDATE", destination_hostgroup=10, apply=1 },
  { rule_id=2, active=1, match_digest="^SELECT .* FROM .*USER.*", destination_hostgroup=10, apply=1 },
  { rule_id=3, active=1, match_digest="^SELECT", destination_hostgroup=20, apply=1 },
  { rule_id=4, active=1, match_digest=".*", destination_hostgroup=10, apply=1 }
)
