# 镜像配置：使用已验证可拉取的镜像源，避免 Docker Hub EOF
MYSQL_IMAGE=docker.m.daocloud.io/library/mysql:8.0
NODE_IMAGE=docker.m.daocloud.io/library/node:20-alpine
NGINX_IMAGE=docker.m.daocloud.io/library/nginx:1.27-alpine
MAVEN_IMAGE=docker.m.daocloud.io/library/maven:3.9.9-eclipse-temurin-21
JRE_IMAGE=docker.m.daocloud.io/library/eclipse-temurin:21-jre
REDIS_IMAGE=docker.m.daocloud.io/library/redis:7-alpine
PROXYSQL_IMAGE=docker.m.daocloud.io/proxysql/proxysql:2.6.2
ELASTICSEARCH_IMAGE=docker.m.daocloud.io/library/elasticsearch:8.14.3

# 数据库配置
MYSQL_ROOT_PASSWORD=root123
MYSQL_DATABASE=FlashSale
TZ=Asia/Shanghai
MYSQL_PRIMARY_PORT=3307
MYSQL_REPLICA_PORT=3308
ELASTICSEARCH_PORT=9200

# 后端配置
BACKEND_SERVER_PORT=6005
BACKEND1_HOST_PORT=8081
BACKEND2_HOST_PORT=8082
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=root123
FRONTEND_PORT=80

# Redis 配置
REDIS_PORT=6379
SPRING_DATA_REDIS_HOST=redis
SPRING_DATA_REDIS_PORT=6379